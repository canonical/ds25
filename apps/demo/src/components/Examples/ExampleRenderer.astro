---
import type { ExampleData } from "./ExampleControls/index.js";
import { ReactRenderer } from "./Renderer/index";
const { example } = Astro.props;
interface Props {
  example: ExampleData;
}
---

<style>
    * {
        font-family: var(--font-family), sans-serif;
        font-size: var(--font-size);
    }
</style>

<div class="ds example">
  {example.type === 'react' &&
          <ReactRenderer client:load example={example}/>}
</div>